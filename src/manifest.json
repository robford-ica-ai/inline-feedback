{
  "manifest_version": 3,
  "name": "Inline Feedback",
  "version": "1.0.0",
  "description": "AI-powered inline feedback with medical materials ontology and real-time translation",
  
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "clipboardWrite"
  ],
  
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [{
    "matches": [
      "<all_urls>"
    ],
    "js": [
      "ontology/enhanced-medical-ontology.js",
      "ontology/research-evidence-db.js",
      "ontology/medical-materials.js",
      "debbie-integration/debbie-api-client.js",
      "debbie-integration/owl2dict-converter.js",
      "debbie-integration/gold-standard-pmid-loader.js",
      "debbie-integration/project-debbie-coordinator.js",
      "content/pdf-extractor.js",
      "content/ui-feedback.js",
      "content/selection-handler.js",
      "content/ontology-highlighter.js",
      "content/content-script.js"
    ],
    "css": [
      "styles/overlay.css",
      "styles/ontology.css"
    ],
    "run_at": "document_idle"
  }],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "commands": {
    "quick-translate": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Quick translate selection"
    },
    "explain-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Explain selected text"
    }
  },
  
  "web_accessible_resources": [{
    "resources": [
      "ontology/*",
      "debbie-integration/*",
      "styles/*"
    ],
    "matches": ["<all_urls>"]
  }],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 