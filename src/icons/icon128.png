<svg width="128" height="128" viewBox="0 0 128 128" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="128" height="128" fill="#667eea" rx="24"/>
  
  <!-- Medical cross icon -->
  <g transform="translate(32, 32)">
    <!-- Vertical bar -->
    <rect x="24" y="8" width="16" height="48" fill="white" rx="2"/>
    <!-- Horizontal bar -->
    <rect x="8" y="24" width="48" height="16" fill="white" rx="2"/>
  </g>
  
  <!-- AI indicator dots -->
  <circle cx="96" cy="32" r="4" fill="white" opacity="0.8"/>
  <circle cx="96" cy="44" r="3" fill="white" opacity="0.6"/>
  <circle cx="96" cy="54" r="2" fill="white" opacity="0.4"/>
  
  <!-- Text indicator -->
  <text x="64" y="100" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">IF</text>
</svg> 